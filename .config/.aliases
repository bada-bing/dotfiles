alias lg=lazygit
alias tn='~/src/scripts/local_development/tmux_sessionizer.sh'
alias tks='tmux kill-server'
alias ts='tmux kill-session'
alias ta='tmux attach'

alias nn=pick_npm_script
alias cat=bat
alias cph='history | tail -n 1 | cut -c 8- | pbcopy'

alias ls='lsd -lah'
alias vim=nvim
alias vv='nvim .'
alias vdot='cd ~/dotfiles; nvim .'
alias gst='git status'
alias gpsh='git push'
alias gpl='git pull'

alias ..='cd ..'
alias ...='cd ../..'

alias bu='brew update-if-needed; brew outdated'
alias buu='brew upgrade'

alias wpr-utils='tmux new-session -d -s wpr-utils "mprocs -c /Users/miki/Documents/toolbox/env/mprocs/wpr-utils.yaml"'
alias szsh='source ~/.config/zsh/.zshrc'
alias hgrep='history 1 | grep'

alias ndx='git clean -ndX'
alias fdx='git clean -fdX'

alias sws='~/src/scripts/dev-env/start_work_session.sh'
alias sss='~/src/scripts/dev-env/start_study_session.sh'

wa-1() {
    (cd /Users/miki/src/wa-1 && npm run start -- "$@")
}